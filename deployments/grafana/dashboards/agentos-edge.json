{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "AgentOS Edge - Request Rate (RPS) by Upstream",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(aegisflow_edge_requests_total[1m])) by (upstream)",
          "legendFormat": "{{upstream}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "reqps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "AgentOS Edge - Active Connections",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "aegisflow_edge_active_connections",
          "legendFormat": "Connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "conn"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "AgentOS Edge - Adaptive Load Shedding Drops",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(aegisflow_loadshed_requests_total[1m])) by (reason)",
          "legendFormat": "Dropped (reason: {{reason}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars"
          },
          "unit": "cps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "title": "AgentOS Edge - Circuit Breaker States",
      "type": "state-timeline",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "aegisflow_circuit_breaker_state",
          "legendFormat": "{{upstream}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 70
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Closed (Healthy)", "color": "green" },
                "1": { "text": "Open (Tripped)", "color": "red" },
                "2": { "text": "Half-Open", "color": "orange" }
              }
            }
          ]
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "title": "LLM Provider Call Latency (P95 comparison)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(aegisflow_provider_latency_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "{{provider}} P95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "s"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 6,
      "title": "Traffic Control Overview (Served vs Rate-Limited vs Shed)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(aegisflow_edge_requests_total{status=~\"2..\"}[1m])) or sum(rate(aegisflow_telemetry_requests_total{status=~\"2..\"}[1m]))",
          "legendFormat": "Served (2xx)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(aegisflow_ratelimit_requests_total[1m]))",
          "legendFormat": "Rate-Limited (429)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(aegisflow_loadshed_requests_total[1m]))",
          "legendFormat": "Shed (503)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "reqps"
        }
      }
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": [
    "agentos",
    "edge"
  ],
  "title": "AgentOS Edge Monitoring Dashboard",
  "timezone": "browser",
  "weekStart": ""
}
